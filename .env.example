# Legacy Made API — example environment
#
# Copy this file to `.env` and fill in real values for local development.
# Values are validated at startup by the Zod schema in `src/config.ts`.
# If a value has a default, it's noted inline.

# GENERAL
# PORT is optional (default: 3000).
# NODE_ENV is optional: one of `development` | `test` | `production` (default: development).
PORT=3000
NODE_ENV=development

# DATABASE
# Two Neon Postgres connection strings. APP runs as the RLS-scoped role;
# MIGRATIONS runs as the owner role for drizzle-kit.
DATABASE_URL_APP=postgres://app_user:...@...neon.tech/legacy_made
DATABASE_URL_MIGRATIONS=postgres://owner:...@...neon.tech/legacy_made

# CORS
# Comma-separated list of allowed origins. Empty by default.
CORS_ALLOWED_ORIGINS=http://localhost:8081,https://app.mylegacymade.com

# CLERK
CLERK_PUBLIC_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Clerk webhook signing secret (from the Clerk dashboard webhook settings).
SIGNING_SECRET=whsec_...

# CLOUDFLARE R2
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=legacy-made-dev

# AWS KMS (E2EE key escrow)
# AWS_KMS_REGION is optional (default: us-east-1).
AWS_KMS_REGION=us-east-1
AWS_KMS_ASYMMETRIC_KEY_ARN=arn:aws:kms:us-east-1:...:key/...
AWS_ACCESS_KEY_ID_KMS=...
AWS_SECRET_ACCESS_KEY_KMS=...

# RESEND (Email Service)
# *_FROM_* and RESEND_FROM_NAME all have sensible production defaults; override for branded dev sandboxes.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL_INVITE=invite@notify.mylegacymade.com
RESEND_FROM_EMAIL_UPDATES=updates@notify.mylegacymade.com
RESEND_FROM_NAME=Legacy Made

# LOOPS (Marketing Email Service)
LOOPS_API_KEY=...

# INVITATION TOKENS
INVITATION_TOKEN_SECRET=change-me-long-random-string
# Optional; defaults to https://app.mylegacymade.com.
INVITATION_BASE_URL=https://app.mylegacymade.com

# FILE UPLOAD
# Both optional; defaults are 1 GiB and 100 MiB respectively.
MAX_FILE_SIZE_BYTES=1073741824
MULTIPART_THRESHOLD_BYTES=104857600

# SUPPORT
# Optional; defaults to support@mylegacymade.com.
SUPPORT_EMAIL=support@mylegacymade.com

# EXPO PUSH NOTIFICATIONS
# Optional. Improves Expo rate limits and prevents token impersonation.
# Push notifications work without it, but production deployments should set it.
EXPO_ACCESS_TOKEN=
# Optional. Comma-separated list of user IDs allowed to receive push notifications in dev.
# Leave empty in production (empty = no allowlist filtering).
PUSH_NOTIFICATION_ALLOWLIST=

# STRIPE
# Pinned API version is set in code (src/stripe/stripe.service.ts). For local dev,
# install the Stripe CLI and run `stripe listen --forward-to localhost:3000/webhooks/stripe`.
# The CLI prints a signing secret on startup — paste it into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=rk_test_...   # restricted key recommended (rk_) over secret key (sk_); see docs/stripe.md
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_INDIVIDUAL=price_...
# Optional. Family tier isn't yet a product offering — leave unset until launched.
# Setting it activates the 'family' tier in checkout + webhook handlers.
# STRIPE_PRICE_ID_FAMILY=price_...

# APP
# Canonical base URL for deep links back into the mobile app and for the web customer-facing site.
# Stripe customer portal redirects to ${APP_BASE_URL}/subscription/return.
# Optional; defaults to https://app.mylegacymade.com.
APP_BASE_URL=https://app.mylegacymade.com

# FEATURE FLAGS
# Optional bool (accepts true/1/false/0). Defaults to false.
# When true, new users are granted a lifetime subscription on signup (dev/demo only).
GRANT_LIFETIME_TO_NEW_USERS=false
